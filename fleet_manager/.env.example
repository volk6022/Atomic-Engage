# Required
DATABASE_URL=postgresql+asyncpg://fleet_user:fleet_password@localhost:5432/fleet_db
REDIS_URL=redis://localhost:6379
API_KEY=change_me_in_production
N8N_SYSTEM_WEBHOOK_URL=https://your-n8n-instance.com/webhook/fleet

# MaxMind GeoIP databases (download from https://dev.maxmind.com/geoip/geolite2/)
GEOIP_CITY_DB_PATH=/path/to/GeoLite2-City.mmdb
GEOIP_ASN_DB_PATH=/path/to/GeoLite2-ASN.mmdb

# PostgreSQL
POSTGRES_USER=fleet_user
POSTGRES_PASSWORD=fleet_password
POSTGRES_DB=fleet_db